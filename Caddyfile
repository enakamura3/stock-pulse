# Configuração do Caddy para Produção e Teste Local (Opção 2A)

# Domínio do Frontend (Produção)
stockpulse.com, www.stockpulse.com {
    # Habilita compressão de conteúdo
    encode zstd gzip

    # Proxy reverso direcionando para o container Next.js
    reverse_proxy frontend:3000
}

# Domínio do Backend (Produção - API & WebSockets)
api.stockpulse.com {
    # Habilita compressão de conteúdo
    encode zstd gzip

    # Proxy reverso direcionando para o container Go
    reverse_proxy backend:8080
}

# Bloco de Desenvolvimento / Teste Local (Acesso HTTP)
http://stockpulse.localhost, http://localhost {
    encode zstd gzip
    reverse_proxy frontend:3000
}

http://api.stockpulse.localhost {
    encode zstd gzip
    reverse_proxy backend:8080
}
